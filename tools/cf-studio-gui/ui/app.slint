import { Button, VerticalBox, HorizontalBox, SpinBox, ComboBox } from "std-widgets.slint";

// One row of the workflow checklist, prepared for display by the Rust
// side (mark/here are precomputed so the markup stays simple).
export struct StepRow {
    number: int,
    title: string,
    mark: string,    // "✓" if done, "○" otherwise
    here: string,    // "   ← you are here" on the project's current step, else ""
    viewing: bool,   // the step currently shown in the body
}

// The live 3D viewport: a wgpu-rendered Image (filled from Rust) with a
// drag-to-orbit TouchArea and an optional placeholder hint. Reused by the
// step-1 scan view and the step-2 editor.
component ScanViewport inherits Rectangle {
    in property <image> view;
    in property <bool> show-hint;
    in property <string> hint;
    callback orbit(length, length);

    vertical-stretch: 1;
    // Low floor so the body yields room to the footer on short windows;
    // it grows to fill on taller ones.
    min-height: 150px;
    background: #e9ebef;
    border-radius: 10px;
    clip: true;

    Image {
        source: view;
        width: 100%;
        height: 100%;
        image-fit: contain;
    }
    if show-hint: Text {
        text: hint;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 17px;
        color: #888888;
        wrap: word-wrap;
    }
    TouchArea {
        property <length> px;
        property <length> py;
        mouse-cursor: grab;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                self.px = self.mouse-x;
                self.py = self.mouse-y;
            }
        }
        moved => {
            root.orbit(self.mouse-x - self.px, self.mouse-y - self.py);
            self.px = self.mouse-x;
            self.py = self.mouse-y;
        }
    }
}

export component AppWindow inherits Window {
    title: "CortenForge Studio";
    preferred-width: 900px;
    preferred-height: 840px;
    min-width: 640px;
    // Tall enough that the footer (Back / Help / Next) is always on-screen
    // even if the OS restores a shorter window from a previous run (and
    // with room for the step-2 trim row).
    min-height: 800px;

    in property <string> project-name: "Untitled";
    in property <[StepRow]> steps;
    in property <int> viewed-number: 1;
    in property <int> total-steps: 6;
    in property <string> viewed-title;
    in property <bool> can-back: false;
    in property <bool> can-next: true;
    in property <string> step-message: "";
    in property <bool> step-message-is-error: false;
    // The live 3D view (rendered by wgpu into a Slint Image) + whether a
    // scan has been loaded yet (drives the step-1 placeholder hint).
    in property <image> scan-view;
    in property <bool> has-scan: false;
    // Step-2 editor: working-mesh stats line ("N faces · M vertices").
    in property <string> edit-stats: "";
    // Whether a centerline exists (after Find floor) — gates the trim row.
    in property <bool> has-centerline: false;
    // Upper bound (mm) for the trim sliders = the centerline arc length.
    in property <int> trim-max-mm: 100;
    // Whether a floor trim is applied — gates the reconstruct row (you
    // reconstruct down to a chopped floor).
    in property <bool> has-floor-trim: false;

    callback back();
    callback next();
    callback help();
    callback pick-scan();
    callback pick-design();
    // Mouse-drag in the 3D view: (dx, dy) screen-pixel deltas → orbit.
    callback orbit(length, length);
    // Step-2 edit ops (drive the EditSession; each re-renders the view).
    // (Auto-center + auto-orient run automatically at load, matching the
    // cf-scan-prep tool; the manual transform controls are Reorient /
    // Recenter sliders, which arrive with the parity phase.)
    callback simplify(int);
    callback weld();
    callback find-floor();
    callback apply-trim(int, int);
    // (shape-index 0=constant/1=taper/2=extrapolate, reference-mm)
    callback apply-reconstruct(int, int);
    callback reset-edit();

    VerticalBox {
        padding: 28px;
        spacing: 16px;

        // ── header ──────────────────────────────────────────────
        Text {
            text: "CortenForge Studio  ·  \{project-name}";
            font-size: 15px;
            color: #888888;
        }
        Text {
            text: "Step \{viewed-number} of \{total-steps}";
            font-size: 15px;
            color: #888888;
        }
        Text {
            text: viewed-title;
            font-size: 30px;
            font-weight: 800;
        }

        // ── body (per-step controls) ────────────────────────────
        Rectangle {
            background: #f3f4f6;
            border-radius: 14px;
            vertical-stretch: 1;
            VerticalBox {
                alignment: center;
                spacing: 16px;

                // Step 1 — add the scan, see it live.
                if viewed-number == 1: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    ScanViewport {
                        view: scan-view;
                        show-hint: !has-scan;
                        hint: "Choose a scan to see it here — then drag to spin it.";
                        orbit(dx, dy) => { root.orbit(dx, dy); }
                    }
                    Button {
                        text: has-scan ? "Choose a different scan…" : "Choose scan file…";
                        clicked => { pick-scan(); }
                    }
                }

                // Step 2 — clean the scan, live, in the same viewport.
                if viewed-number == 2: VerticalLayout {
                    spacing: 12px;
                    vertical-stretch: 1;
                    ScanViewport {
                        view: scan-view;
                        show-hint: !has-scan;
                        hint: "Add a scan in step 1 first.";
                        orbit(dx, dy) => { root.orbit(dx, dy); }
                    }
                    Text {
                        text: edit-stats;
                        horizontal-alignment: center;
                        font-size: 15px;
                        color: #555555;
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Button { text: "Weld"; clicked => { weld(); } }
                        Text { text: "Simplify to"; vertical-alignment: center; color: #333333; }
                        target-spin := SpinBox {
                            minimum: 1000;
                            maximum: 1000000;
                            value: 200000;
                        }
                        Button { text: "Simplify"; clicked => { simplify(target-spin.value); } }
                        Button { text: "Find floor"; clicked => { find-floor(); } }
                        Button { text: "Reset"; clicked => { reset-edit(); } }
                    }
                    // Trim row — appears once Find floor has traced a
                    // centerline to chop along.
                    if has-centerline: HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "Trim  tip"; vertical-alignment: center; color: #333333; }
                        tip-spin := SpinBox {
                            minimum: 0;
                            maximum: trim-max-mm;
                            value: 0;
                        }
                        Text { text: "mm   floor"; vertical-alignment: center; color: #333333; }
                        floor-spin := SpinBox {
                            minimum: 0;
                            maximum: trim-max-mm;
                            value: 0;
                        }
                        Text { text: "mm"; vertical-alignment: center; color: #333333; }
                        Button {
                            text: "Apply trim";
                            clicked => { apply-trim(tip-spin.value, floor-spin.value); }
                        }
                    }
                    // Reconstruct row — appears once a floor trim is applied;
                    // closes the chopped floor with a profiled cap.
                    if has-floor-trim: HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "Floor shape"; vertical-alignment: center; color: #333333; }
                        shape-combo := ComboBox {
                            model: ["Constant", "Taper", "Extrapolate"];
                            current-index: 0;
                        }
                        Text { text: "from"; vertical-alignment: center; color: #333333; }
                        ref-spin := SpinBox {
                            minimum: 5;
                            maximum: trim-max-mm;
                            value: 25;
                        }
                        Text { text: "mm above cut"; vertical-alignment: center; color: #333333; }
                        Button {
                            text: "Reconstruct floor";
                            clicked => { apply-reconstruct(shape-combo.current-index, ref-spin.value); }
                        }
                    }
                }

                if viewed-number == 3: Button {
                    text: "Choose design file…";
                    clicked => { pick-design(); }
                }
                if viewed-number >= 4: Text {
                    text: "“\{viewed-title}” — the controls for this step arrive next.";
                    horizontal-alignment: center;
                    font-size: 18px;
                    color: #666666;
                    wrap: word-wrap;
                }

                if step-message != "": Text {
                    text: step-message;
                    horizontal-alignment: center;
                    font-size: 17px;
                    color: step-message-is-error ? #c62828 : #2e7d32;
                    wrap: word-wrap;
                }
            }
        }

        // ── progress checklist (reflects the real project state) ──
        VerticalBox {
            spacing: 6px;
            for row in steps: Text {
                text: "\{row.mark}  Step \{row.number}: \{row.title}\{row.here}";
                font-size: 17px;
                font-weight: row.viewing ? 700 : 400;
                color: row.viewing ? #1565c0 : #222222;
            }
        }

        // ── footer ──────────────────────────────────────────────
        HorizontalBox {
            spacing: 12px;
            Button {
                text: "← Back";
                enabled: can-back;
                clicked => { back(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Help";
                clicked => { help(); }
            }
            Button {
                text: "Next →";
                enabled: can-next;
                primary: true;
                clicked => { next(); }
            }
        }
    }
}
