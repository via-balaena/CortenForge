import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

// One row of the workflow checklist, prepared for display by the Rust
// side (mark/here are precomputed so the markup stays simple).
export struct StepRow {
    number: int,
    title: string,
    mark: string,    // "✓" if done, "○" otherwise
    here: string,    // "   ← you are here" on the project's current step, else ""
    viewing: bool,   // the step currently shown in the body
}

export component AppWindow inherits Window {
    title: "CortenForge Studio";
    preferred-width: 900px;
    preferred-height: 780px;
    min-width: 640px;
    // Tall enough that the footer (Back / Help / Next) is always on-screen
    // even if the OS restores a shorter window from a previous run.
    min-height: 700px;

    in property <string> project-name: "Untitled";
    in property <[StepRow]> steps;
    in property <int> viewed-number: 1;
    in property <int> total-steps: 6;
    in property <string> viewed-title;
    in property <bool> can-back: false;
    in property <bool> can-next: true;
    in property <string> step-message: "";
    in property <bool> step-message-is-error: false;
    // The live 3D scan view (rendered by wgpu into a Slint Image) + whether
    // a scan has been loaded yet (drives the placeholder hint).
    in property <image> scan-view;
    in property <bool> has-scan: false;

    callback back();
    callback next();
    callback help();
    callback pick-scan();
    callback pick-prep();
    callback pick-design();
    // Mouse-drag in the 3D view: (dx, dy) screen-pixel deltas → orbit.
    callback orbit(length, length);

    VerticalBox {
        padding: 28px;
        spacing: 16px;

        // ── header ──────────────────────────────────────────────
        Text {
            text: "CortenForge Studio  ·  \{project-name}";
            font-size: 15px;
            color: #888888;
        }
        Text {
            text: "Step \{viewed-number} of \{total-steps}";
            font-size: 15px;
            color: #888888;
        }
        Text {
            text: viewed-title;
            font-size: 30px;
            font-weight: 800;
        }

        // ── body (per-step controls) ────────────────────────────
        Rectangle {
            background: #f3f4f6;
            border-radius: 14px;
            vertical-stretch: 1;
            VerticalBox {
                alignment: center;
                spacing: 16px;

                if viewed-number == 1: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    // ── live 3D scan viewport (drag to orbit) ──
                    Rectangle {
                        vertical-stretch: 1;
                        // Low floor so the body yields room to the footer on
                        // short windows; it grows to fill on taller ones.
                        min-height: 150px;
                        background: #e9ebef;
                        border-radius: 10px;
                        clip: true;
                        Image {
                            source: scan-view;
                            width: 100%;
                            height: 100%;
                            image-fit: contain;
                        }
                        if !has-scan: Text {
                            text: "Choose a scan to see it here — then drag to spin it.";
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 17px;
                            color: #888888;
                            wrap: word-wrap;
                        }
                        TouchArea {
                            property <length> px;
                            property <length> py;
                            mouse-cursor: has-scan ? MouseCursor.grab : MouseCursor.default;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    self.px = self.mouse-x;
                                    self.py = self.mouse-y;
                                }
                            }
                            moved => {
                                root.orbit(self.mouse-x - self.px, self.mouse-y - self.py);
                                self.px = self.mouse-x;
                                self.py = self.mouse-y;
                            }
                        }
                    }
                    Button {
                        text: has-scan ? "Choose a different scan…" : "Choose scan file…";
                        clicked => { pick-scan(); }
                    }
                }
                if viewed-number == 2: Button {
                    text: "Choose cleaned scan + prep…";
                    clicked => { pick-prep(); }
                }
                if viewed-number == 3: Button {
                    text: "Choose design file…";
                    clicked => { pick-design(); }
                }
                if viewed-number >= 4: Text {
                    text: "“\{viewed-title}” — the controls for this step arrive next.";
                    horizontal-alignment: center;
                    font-size: 18px;
                    color: #666666;
                    wrap: word-wrap;
                }

                if step-message != "": Text {
                    text: step-message;
                    horizontal-alignment: center;
                    font-size: 17px;
                    color: step-message-is-error ? #c62828 : #2e7d32;
                    wrap: word-wrap;
                }
            }
        }

        // ── progress checklist (reflects the real project state) ──
        VerticalBox {
            spacing: 6px;
            for row in steps: Text {
                text: "\{row.mark}  Step \{row.number}: \{row.title}\{row.here}";
                font-size: 17px;
                font-weight: row.viewing ? 700 : 400;
                color: row.viewing ? #1565c0 : #222222;
            }
        }

        // ── footer ──────────────────────────────────────────────
        HorizontalBox {
            spacing: 12px;
            Button {
                text: "← Back";
                enabled: can-back;
                clicked => { back(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Help";
                clicked => { help(); }
            }
            Button {
                text: "Next →";
                enabled: can-next;
                primary: true;
                clicked => { next(); }
            }
        }
    }
}
