import { Button, VerticalBox, HorizontalBox, LineEdit, ComboBox, CheckBox, ScrollView } from "std-widgets.slint";

// One silicone layer in the step-3 stack editor (innermost first). The Rust
// side owns these in a VecModel; the row widgets write back via callbacks.
export struct LayerRow {
    material-index: int,  // index into `material-names` / the catalog
    thickness-mm: int,
    slacker-pct: int,
}

// One axisymmetric grip ring in the step-4 interior-ridge editor. The Rust
// side owns these in a VecModel (mirroring LayerRow); rows write back via
// the set-ring-* callbacks. Integer UI units: position/width as percents,
// depth in tenths of a millimetre (so 0.1 mm resolution on a plain SpinBox).
export struct RingRow {
    position-pct: int,     // axial position, 0 = opening … 100 = deep end
    depth-tenths-mm: int,  // inward pinch depth, ×0.1 mm
    width-pct: int,        // half-width of the ring's axial support, %
}

// One generatable cast part in the step-4 part picker. The Rust side owns
// these in a VecModel (parallel to its own `Vec<PartId>`); a checkbox writes
// `checked` back via `set-part-checked`.
export struct PartRow {
    label: string,
    checked: bool,
}

// One row of the workflow checklist, prepared for display by the Rust
// side (mark/here are precomputed so the markup stays simple).
export struct StepRow {
    number: int,
    title: string,
    mark: string,    // "✓" if done, "○" otherwise
    here: string,    // "   ← you are here" on the project's current step, else ""
    viewing: bool,   // the step currently shown in the body
}

// The live 3D viewport: a wgpu-rendered Image (filled from Rust) with a
// drag-to-orbit TouchArea and an optional placeholder hint. Reused by the
// step-1 scan view and the step-2 editor.
component ScanViewport inherits Rectangle {
    in property <image> view;
    in property <bool> show-hint;
    in property <string> hint;
    // Fixed height (overridden per step) — the body is scrollable, where a
    // stretchy viewport would collapse to nothing.
    in property <length> view-height: 300px;
    callback orbit(length, length);

    height: root.view-height;
    background: #e9ebef;
    border-radius: 10px;
    clip: true;

    Image {
        source: view;
        width: 100%;
        height: 100%;
        image-fit: contain;
    }
    if show-hint: Text {
        text: hint;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 17px;
        color: #5a5a5a;
        wrap: word-wrap;
    }
    TouchArea {
        property <length> px;
        property <length> py;
        mouse-cursor: grab;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                self.px = self.mouse-x;
                self.py = self.mouse-y;
            }
        }
        moved => {
            root.orbit(self.mouse-x - self.px, self.mouse-y - self.py);
            self.px = self.mouse-x;
            self.py = self.mouse-y;
        }
    }
}

// One numbered sub-step of the step-2 cleanup flow: a sequence heading
// ("First — …", "Then — …") + a one-line plain-language hint, with its
// controls injected below via @children. Laid out top-to-bottom so the
// cleanup page reads as an obvious order rather than a flat toolbar.
component CleanupSection inherits VerticalLayout {
    in property <string> heading;
    in property <string> hint;
    in property <bool> done: false;
    spacing: 4px;
    Text {
        text: root.done ? root.heading + "   ✓" : root.heading;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        color: root.done ? #2e7d32 : #1a1a1a;
    }
    if root.hint != "": Text {
        text: root.hint;
        font-size: 13px;
        horizontal-alignment: center;
        color: #5f5f5f;
        wrap: word-wrap;
    }
    @children
}

// A numeric stepper — a drop-in for std-widgets `SpinBox` (same `minimum` /
// `maximum` / `value` / `enabled` / `edited(int)` interface) that deliberately
// does NOT react to the mouse wheel. The built-in SpinBox steps its value on
// scroll, which fights the page ScrollView (and the live preview); this widget
// is a plain text field + −/+ buttons, so scrolling over it just scrolls the
// page. Type a number or click the arrows to change it.
component StepBox inherits HorizontalLayout {
    in property <int> minimum: 0;
    in property <int> maximum: 1000000;
    in-out property <int> value: 0;
    in property <bool> enabled: true;
    callback edited(int);
    // Set by typing, cleared on commit — so focus-out only re-notifies when the
    // user actually changed something (no spurious re-mesh on a bare click-in/out).
    property <bool> pending: false;

    spacing: 4px;
    alignment: stretch;

    function clamp(v: int) -> int {
        return v < root.minimum ? root.minimum : (v > root.maximum ? root.maximum : v);
    }
    // Apply + notify (the `edited` re-mesh) and clear the pending edit.
    function commit(v: int) {
        root.pending = false;
        root.value = root.clamp(v);
        root.edited(root.value);
    }

    Button {
        text: "−";
        enabled: root.enabled && root.value > root.minimum;
        clicked => { root.commit(root.value - 1); }
    }
    edit := LineEdit {
        horizontal-stretch: 1;
        min-width: 56px;
        enabled: root.enabled;
        input-type: number;
        horizontal-alignment: center;
        text: "\{root.value}";
        // Typing keeps `value` current (so the field is right) but does NOT
        // re-mesh — that would freeze the UI mid-type. The value is APPLIED (the
        // bound property updated + the preview re-meshed) on Enter, on the −/+
        // buttons, or on focus-out — so a typed-but-not-Entered value is never
        // silently dropped by a later Continue / Use this design / Make molds.
        edited => {
            if (self.text != "") {
                // Keep `value` current per keystroke but do NOT clamp here —
                // clamping mid-type snaps the field to the bound on overshoot
                // (jarring). The value is clamped on commit (Enter / blur / +-).
                root.value = self.text.to-float();
                root.pending = true;
            }
        }
        accepted => { root.commit(root.value); }
        changed has-focus => {
            if (!self.has-focus && root.pending) {
                root.commit(root.value);
            }
        }
    }
    Button {
        text: "+";
        enabled: root.enabled && root.value < root.maximum;
        clicked => { root.commit(root.value + 1); }
    }
}

// First-launch liability waiver + age gate. Rendered as a full-window opaque
// overlay on top of the wizard on EVERY launch (acceptance is held in memory
// only and never persisted), so the wizard cannot be used until the user
// confirms. `accept()` clears the gate for the session; `quit()` closes the app.
//
// ⚠ PLACEHOLDER WORDING — NOT LEGAL ADVICE. The disclaimer and 18+
// confirmation below are a reasonable template only. Via Balaena's legal
// counsel MUST review and replace this text before any public release.
component WaiverPage inherits Rectangle {
    callback accept();
    callback quit();

    // Opaque (matches the window background) so the wizard underneath is fully
    // hidden until the waiver is accepted.
    background: #dce0e5;

    // The required confirmation checkbox gates the "Agree & Continue" button.
    property <bool> agreed: false;

    Rectangle {
        // Centered card, capped so it stays readable on large screens and
        // shrinks (with the inner ScrollView) on small ones.
        width: min(640px, parent.width - 56px);
        height: min(760px, parent.height - 56px);
        background: #f3f4f6;
        border-radius: 14px;

        VerticalBox {
            padding: 28px;
            spacing: 16px;

            Text {
                text: "Before you begin";
                font-size: 30px;
                font-weight: 800;
                color: #1a1a1a;
            }

            terms-scroll := ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    width: terms-scroll.visible-width;
                    spacing: 14px;

                    Text {
                        text: "Cendrillon is provided by Via Balaena as a design-assistance tool. It generates molds and casting plans for custom silicone devices from your own 3D scans.";
                        font-size: 16px;
                        color: #1a1a1a;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "You are solely responsible for how you use this software and for anything you make with it. Via Balaena makes no warranty that the software or its outputs are safe, accurate, fit for any purpose, or suitable for use on or in the body. Material selection, manufacture, curing, cleaning, and use are entirely at your own risk. To the fullest extent permitted by law, Via Balaena disclaims all liability for any injury, loss, or damage arising from use of this software or its outputs.";
                        font-size: 16px;
                        color: #1a1a1a;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "This software and the devices it helps you create are intended for adults only.";
                        font-size: 16px;
                        font-weight: 700;
                        color: #1a1a1a;
                        wrap: word-wrap;
                    }
                    Text {
                        text: "By continuing you confirm that you are at least 18 years old and that you have read and accept these terms.";
                        font-size: 16px;
                        color: #1a1a1a;
                        wrap: word-wrap;
                    }
                }
            }

            CheckBox {
                text: "I confirm I am 18 or older and accept the terms above.";
                toggled => { root.agreed = self.checked; }
            }

            HorizontalBox {
                spacing: 12px;
                Button {
                    text: "Quit";
                    clicked => { root.quit(); }
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Agree & Continue";
                    primary: true;
                    enabled: root.agreed;
                    clicked => { root.accept(); }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Cendrillon";
    preferred-width: 900px;
    preferred-height: 900px;
    min-width: 640px;
    // Tall enough that the footer (Back / Help / Next) is always on-screen
    // even if the OS restores a shorter window from a previous run (and
    // with room for the step-2 trim row).
    min-height: 850px;
    // Force a consistent light theme (the app is designed light: light body
    // panel, dark text). Without this the window inherits the OS scheme — on
    // macOS dark mode the off-panel text (progress checklist) went dark-on-
    // dark and vanished.
    background: #dce0e5;

    // First-launch liability/age gate. False each launch (never persisted), so
    // the WaiverPage overlay below covers the wizard until `accept-waiver()`.
    in property <bool> waiver-accepted: false;

    in property <string> project-name: "Untitled";
    in property <[StepRow]> steps;
    in property <int> viewed-number: 1;
    in property <int> total-steps: 7;
    in property <string> viewed-title;
    in property <bool> can-back: false;
    in property <bool> can-next: true;
    in property <string> step-message: "";
    in property <bool> step-message-is-error: false;
    // The live 3D view (rendered by wgpu into a Slint Image) + whether a
    // scan has been loaded yet (drives the step-1 placeholder hint).
    in property <image> scan-view;
    in property <bool> has-scan: false;
    // Step-2 editor: working-mesh stats line ("N faces · M vertices").
    in property <string> edit-stats: "";
    // Whether a centerline exists (after Find floor) — gates the trim row.
    in property <bool> has-centerline: false;
    // Upper bound (mm) for the trim sliders = the centerline arc length.
    in property <int> trim-max-mm: 100;
    // Whether a floor trim is applied — gates the reconstruct row (you
    // reconstruct down to a chopped floor).
    in property <bool> has-floor-trim: false;
    // True while a background Simplify is running — disables the edit +
    // pick-scan buttons so an intervening edit can't be clobbered by the
    // late-arriving result. Orbit stays live.
    in property <bool> busy: false;
    // Step 3 design editor: the silicone layer stack + the catalog's display
    // names for each layer's material picker.
    in property <[LayerRow]> layers;
    in property <[string]> material-names;
    // Step 4: a persistent summary of the generated molds (piece counts,
    // total silicone mass, pour plan, output folder). Empty until a run
    // completes; survives leaving + returning to the step.
    in property <string> molds-summary: "";
    // Step 3 "Shape your piece": the cavity inset (snugness, mm) + the optional
    // surface-ridge feature. `cavity-inset-mm` turns the scan into the plug;
    // `ridges-enabled` toggles the ridges; the scalar knobs hold the sanitized
    // sub-feature values (lengths in tenths-of-mm, orientation in degrees). The
    // one field rides every offset (plug + shells). The grip rings are a
    // Rust-owned VecModel (mirrors `layers`).
    in-out property <int> cavity-inset-mm: 5;
    in-out property <bool> ridges-enabled: false;
    // Per-feature toggles (default on, so flipping `ridges-enabled` reproduces
    // the validated full canal). Each gates whether that feature contributes:
    // off → that part of the field is dropped (rings emptied / depth 0 / 0°).
    in-out property <bool> rings-enabled: true;
    in-out property <bool> texture-enabled: true;
    in-out property <bool> side-pinch-enabled: true;
    in-out property <bool> tip-relief-enabled: true;
    in-out property <bool> orientation-enabled: true;
    in property <[RingRow]> ridge-rings;
    in-out property <int> ridge-texture-depth-tenths-mm: 15;    // 1.5 mm
    in-out property <int> ridge-texture-spacing-tenths-mm: 80;  // 8.0 mm
    in-out property <int> ridge-side-pinch-tenths-mm: 15;       // 1.5 mm
    in-out property <int> ridge-tip-relief-tenths-mm: 30;       // 3.0 mm
    in-out property <int> ridge-orientation-deg: 0;
    // Step 3: the live plug preview (wgpu-rendered) of the real cleaned scan
    // offset inward by the inset + textured with the ridges.
    in property <image> texture-preview;
    // Step 5: the generatable parts (per-layer cups/plugs + accessories),
    // each with a checkbox. Default all-checked = full cast; uncheck to
    // generate only some pieces. Rust-owned VecModel, rebuilt when the
    // design's layer count changes; make-molds reads the checked mask.
    in property <[PartRow]> parts;
    // Step 5 (Print): status line — "ready to save N file(s)" before
    // export, "saved to <dir>" after. Empty until the molds are made.
    in property <string> print-summary: "";
    // Whether the print files have been exported (gates the Open-folder
    // button + flips the save button to a re-save).
    in property <bool> has-print-export: false;
    // Step 6 (Pour assistant): the full plan overview + the active-layer
    // instruction + the live pot-life countdown (text + urgency 0/1/2 for
    // colour) + whether a countdown is running + whether every layer is
    // poured (the finished state).
    in property <string> pour-plan-text: "";
    in property <string> pour-active-text: "";
    in property <string> pour-timer-text: "";
    in property <int> pour-timer-urgency: 0;
    in property <bool> pour-timer-running: false;
    in property <bool> pour-complete: false;

    // First-launch waiver gate: accept clears the overlay for the session;
    // quit closes the app from the gate (wired in main.rs).
    callback accept-waiver();
    callback quit-app();

    callback back();
    callback next();
    callback help();
    callback pick-scan();
    callback pick-design();
    // Step-4 layer-stack edits + commit (the cavity inset lives on step 3).
    callback add-layer();
    callback remove-layer(int);
    callback set-layer-material(int, int);
    callback set-layer-thickness(int, int);
    callback set-layer-slacker(int, int);
    callback use-design();
    // Step 5: run the cast at a quality preset matching the picker order
    // (0 = Fine 0.5 mm print quality, 1 = Fast 1.5 mm preview). Long-running
    // — driven async on a background thread. The ridge state is read off the
    // plug committed on step 3.
    callback make-molds(int);
    // Step-3 surface-ridge grip-ring editor (mirrors the layer callbacks).
    callback add-ring();
    callback remove-ring(int);
    callback set-ring-position(int, int);
    callback set-ring-depth(int, int);
    callback set-ring-width(int, int);
    // Step 3: commit the shaped plug (cavity inset mm + ridges) and advance.
    callback commit-plug(int);
    // Step 3: page entry (build the cached real-scan preview) / a control
    // changed (re-mesh from the cache); and drag-to-orbit the preview viewport.
    callback shape-enter();
    callback shape-changed();
    callback texture-orbit(length, length);
    // Step-4 part picker: toggle one part, or select all / none.
    callback set-part-checked(int, bool);
    callback select-all-parts();
    callback select-no-parts();
    // Step 5: copy the printable files into a chosen folder, and reveal an
    // already-exported folder in the OS file manager.
    callback export-print();
    callback open-export-folder();
    // Step 6: start the current layer's pot-life countdown, and mark the
    // current layer poured (advancing to the next, or finishing).
    callback start-pour-timer();
    callback mark-poured();
    // Mouse-drag in the 3D view: (dx, dy) screen-pixel deltas → orbit.
    callback orbit(length, length);
    // Step-2 edit ops (drive the EditSession; each re-renders the view).
    // (Auto-center + auto-orient run automatically at load, matching the
    // cf-scan-prep tool; the manual transform controls are Reorient /
    // Recenter sliders, which arrive with the parity phase.)
    callback simplify(int);
    callback weld();
    callback find-floor();
    callback apply-trim(int, int);
    // (shape-index 0=constant/1=taper/2=extrapolate, reference-mm)
    callback apply-reconstruct(int, int);
    callback reset-edit();
    // (taubin smoothing iterations) → write cleaned.stl + .prep.toml.
    callback save(int);

    VerticalBox {
        padding: 28px;
        spacing: 16px;

        // ── header ──────────────────────────────────────────────
        Text {
            text: "Cendrillon";
            font-size: 15px;
            color: #5a5a5a;
        }
        Text {
            text: "Step \{viewed-number} of \{total-steps}";
            font-size: 15px;
            color: #5a5a5a;
        }
        Text {
            text: viewed-title;
            font-size: 30px;
            font-weight: 800;
            // Explicit so it doesn't follow the OS scheme (light-on-light).
            color: #1a1a1a;
        }

        // ── body: a persistent 3D viewbox (fixed, for the steps where you
        // view the plug while editing it) above an independently-scrolling
        // controls area, so the view stays put while you scroll the controls.
        // The footer (Back/Next) stays fixed below. ──────
        Rectangle {
            background: #f3f4f6;
            border-radius: 14px;
            vertical-stretch: 1;
            clip: true;
            VerticalLayout {
                padding: 18px;
                spacing: 12px;

                // The fixed viewbox — only the view-bearing steps (1/2 the
                // scan, 3 the plug). It never scrolls; the controls below do.
                if viewed-number == 1 || viewed-number == 2: ScanViewport {
                    view: scan-view;
                    view-height: 320px;
                    show-hint: !has-scan;
                    hint: viewed-number == 2
                        ? "Add a scan in step 1 first."
                        : "Choose a scan to see it here — then drag to spin it.";
                    orbit(dx, dy) => { root.orbit(dx, dy); }
                }
                if viewed-number == 3: ScanViewport {
                    view: texture-preview;
                    view-height: 320px;
                    orbit(dx, dy) => { texture-orbit(dx, dy); }
                }

            body-scroll := ScrollView {
                vertical-stretch: 1;
            VerticalBox {
                width: body-scroll.visible-width;
                padding: 0px;
                spacing: 16px;

                // The status line sits at the top of the controls (right under
                // the viewbox) so it's always visible — not buried at the
                // bottom of a long, scrolling step.
                if step-message != "": Text {
                    text: step-message;
                    horizontal-alignment: center;
                    font-size: 17px;
                    color: step-message-is-error ? #c62828 : #2e7d32;
                    wrap: word-wrap;
                }

                // Step 1 — add the scan, see it live.
                if viewed-number == 1: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    Button {
                        text: has-scan ? "Choose a different scan…" : "Choose scan file…";
                        enabled: !busy;
                        clicked => { pick-scan(); }
                    }
                    Text {
                        text: "Works with STL, OBJ, PLY, and 3MF scans.";
                        horizontal-alignment: center;
                        font-size: 13px;
                        color: #5f5f5f;
                    }
                    Text {
                        text: "💡 Leave the bottom open — scan it like it's on a lazy Susan and don't bother closing or capping the floor in your scanning software. CortenForge trims and rebuilds the floor for you in the next step.";
                        horizontal-alignment: center;
                        font-size: 17px;
                        font-weight: 600;
                        color: #444444;
                        wrap: word-wrap;
                    }
                }

                // Step 2 — clean the scan, live, in the same viewport.
                // Laid out as an ordered sequence (First → Then → Next →
                // Finally) so the cleanup order is obvious, with later steps
                // revealed as earlier ones complete.
                if viewed-number == 2: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    Text {
                        text: edit-stats;
                        horizontal-alignment: center;
                        font-size: 15px;
                        color: #555555;
                    }

                    // First — tidy the raw scan.
                    CleanupSection {
                        heading: "First — tidy the scan";
                        hint: "Merge duplicate points so the rest works. A very heavy scan can be lightened, too.";
                        HorizontalBox {
                            alignment: center;
                            spacing: 8px;
                            Button { text: "Weld points"; enabled: !busy; clicked => { weld(); } }
                            Text { text: "Simplify to"; vertical-alignment: center; color: #333333; }
                            target-spin := StepBox {
                                enabled: !busy;
                                minimum: 1000;
                                maximum: 1000000;
                                value: 200000;
                            }
                            Button { text: "Simplify"; enabled: !busy; clicked => { simplify(target-spin.value); } }
                        }
                    }

                    // Then — stand it upright (find floor + level). Required.
                    CleanupSection {
                        heading: "Then — stand it upright";
                        hint: "Finds the open end and stands the scan vertical. Needed before you can save.";
                        done: has-centerline;
                        HorizontalBox {
                            alignment: center;
                            Button {
                                text: has-centerline ? "Find floor again" : "Find floor";
                                enabled: !busy;
                                clicked => { find-floor(); }
                            }
                        }
                    }

                    // Next — trim the ragged open end (appears after upright).
                    if has-centerline: CleanupSection {
                        heading: "Next — trim the open end";
                        hint: "Trim the ragged open edge. Removing about 10 mm from the floor is a good start.";
                        HorizontalBox {
                            alignment: center;
                            spacing: 8px;
                            Text { text: "from tip"; vertical-alignment: center; color: #333333; }
                            tip-spin := StepBox { minimum: 0; maximum: trim-max-mm; value: 0; }
                            Text { text: "mm    from floor"; vertical-alignment: center; color: #333333; }
                            floor-spin := StepBox { minimum: 0; maximum: trim-max-mm; value: 10; }
                            Text { text: "mm"; vertical-alignment: center; color: #333333; }
                            Button {
                                text: "Apply trim";
                                enabled: !busy;
                                clicked => { apply-trim(tip-spin.value, floor-spin.value); }
                            }
                        }
                        // Re-cap the chopped floor (optional) — titled so it's
                        // clear this rebuilds the floor you just trimmed off.
                        if has-floor-trim: VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "Rebuild the trimmed floor";
                                font-size: 13px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                color: #1a1a1a;
                            }
                            Text {
                                text: "Close the open end back up with a clean floor, rebuilt from the scan's shape just above the cut.";
                                font-size: 12px;
                                horizontal-alignment: center;
                                color: #5f5f5f;
                                wrap: word-wrap;
                            }
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                Text { text: "Shape"; vertical-alignment: center; color: #333333; }
                                shape-combo := ComboBox {
                                    model: ["Flat", "Taper", "Extrapolate"];
                                    current-index: 0;
                                }
                                Text { text: "from"; vertical-alignment: center; color: #333333; }
                                ref-spin := StepBox { minimum: 5; maximum: trim-max-mm; value: 25; }
                                Text { text: "mm above cut"; vertical-alignment: center; color: #333333; }
                                Button {
                                    text: "Reconstruct floor";
                                    enabled: !busy;
                                    clicked => { apply-reconstruct(shape-combo.current-index, ref-spin.value); }
                                }
                            }
                        }
                    }

                    // Finally — save (disabled until upright).
                    CleanupSection {
                        heading: "Finally — save your cleaned scan";
                        hint: has-centerline ? "" : "Do “stand it upright” above first.";
                        HorizontalBox {
                            alignment: center;
                            spacing: 8px;
                            Text { text: "Smoothing"; vertical-alignment: center; color: #333333; }
                            smooth-spin := StepBox { minimum: 0; maximum: 30; value: 8; }
                            Button {
                                text: "Save cleaned scan";
                                primary: true;
                                enabled: !busy && has-centerline;
                                clicked => { save(smooth-spin.value); }
                            }
                        }
                    }

                    // Start over (secondary; small, centered).
                    HorizontalBox {
                        alignment: center;
                        Button { text: "Start over"; enabled: !busy; clicked => { reset-edit(); } }
                    }
                }

                // Step 4 — choose the silicone layer stack (built outward off
                // the shaped plug; the cavity inset lives on "Shape your piece").
                if viewed-number == 4: VerticalLayout {
                    spacing: 12px;
                    vertical-stretch: 1;
                    Text {
                        text: "Choose the silicone layers, innermost first — soft inside, firmer outside. These build outward off the plug you just shaped.";
                        horizontal-alignment: center;
                        font-size: 16px;
                        color: #444444;
                        wrap: word-wrap;
                    }
                    // Layer rows flow at full height; the body scrolls if the
                    // stack gets long (no nested scroll area, which would
                    // collapse to its min-height inside the scrollable body).
                    VerticalLayout {
                        spacing: 6px;
                        for layer[idx] in layers: HorizontalBox {
                            alignment: center;
                            spacing: 6px;
                            Text {
                                text: "Layer \{idx + 1}";
                                vertical-alignment: center;
                                color: #333333;
                            }
                            ComboBox {
                                model: material-names;
                                current-index: layer.material-index;
                                selected => { set-layer-material(idx, self.current-index); }
                            }
                            StepBox {
                                minimum: 0;
                                maximum: 100;
                                value: layer.slacker-pct;
                                edited(v) => { set-layer-slacker(idx, v); }
                            }
                            Text { text: "% slacker"; vertical-alignment: center; color: #333333; }
                            StepBox {
                                minimum: 1;
                                maximum: 100;
                                value: layer.thickness-mm;
                                edited(v) => { set-layer-thickness(idx, v); }
                            }
                            Text { text: "mm"; vertical-alignment: center; color: #333333; }
                            Button { text: "✕"; clicked => { remove-layer(idx); } }
                        }
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Button { text: "+ Add layer"; clicked => { add-layer(); } }
                        Button {
                            text: "Use this design";
                            primary: true;
                            clicked => { use-design(); }
                        }
                        Button { text: "…or load a file"; clicked => { pick-design(); } }
                    }
                }
                // Step 3 — Shape your piece: cavity inset (snugness) + the
                // surface ridges, previewed on the REAL cleaned scan. One edit
                // surface that propagates to the plug and every shell.
                if viewed-number == 3: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    init => { shape-enter(); }
                    Text {
                        text: "Shape your piece: set how snugly it fits, and optionally add ridges. The ridges ride the whole piece, so the wall stays even. The preview above is your real scan — drag to rotate; your part is cast at full detail.";
                        horizontal-alignment: center;
                        font-size: 16px;
                        color: #444444;
                        wrap: word-wrap;
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "Cavity inset (snugness)";
                            vertical-alignment: center;
                            color: #333333;
                        }
                        StepBox {
                            minimum: 0;
                            maximum: 30;
                            value: cavity-inset-mm;
                            edited(v) => { cavity-inset-mm = v; shape-changed(); }
                        }
                        Text { text: "mm"; vertical-alignment: center; color: #333333; }
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 6px;
                        CheckBox {
                            checked <=> ridges-enabled;
                            enabled: !busy;
                            toggled => { shape-changed(); }
                        }
                        Text {
                            text: "Add surface ridges (advanced)";
                            color: #333333;
                            vertical-alignment: center;
                        }
                    }
                    if ridges-enabled: Rectangle {
                        background: #f4f1ea;
                        border-radius: 10px;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;
                            Text {
                                text: "Ridges mesh the piece at fine 0.5 mm detail, so a run with them takes print-quality time.";
                                font-size: 14px;
                                color: #6b5f44;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }
                            // Grip rings — toggle the whole ring set on/off.
                            HorizontalBox {
                                alignment: center;
                                spacing: 6px;
                                CheckBox {
                                    checked <=> rings-enabled;
                                    enabled: !busy;
                                    toggled => { shape-changed(); }
                                }
                                Text {
                                    text: "Grip rings";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: #333333;
                                    vertical-alignment: center;
                                }
                            }
                            VerticalLayout {
                                spacing: 6px;
                                for ring[idx] in ridge-rings: HorizontalBox {
                                    alignment: center;
                                    spacing: 6px;
                                    Text { text: "Ring \{idx + 1}"; vertical-alignment: center; color: #333333; }
                                    StepBox {
                                        minimum: 0;
                                        maximum: 100;
                                        value: ring.position-pct;
                                        enabled: rings-enabled && !busy;
                                        edited(v) => { set-ring-position(idx, v); shape-changed(); }
                                    }
                                    Text { text: "% along"; vertical-alignment: center; color: #333333; }
                                    StepBox {
                                        minimum: 0;
                                        maximum: 100;
                                        value: ring.depth-tenths-mm;
                                        enabled: rings-enabled && !busy;
                                        edited(v) => { set-ring-depth(idx, v); shape-changed(); }
                                    }
                                    Text { text: "×0.1 mm deep"; vertical-alignment: center; color: #333333; }
                                    StepBox {
                                        minimum: 1;
                                        maximum: 50;
                                        value: ring.width-pct;
                                        enabled: rings-enabled && !busy;
                                        edited(v) => { set-ring-width(idx, v); shape-changed(); }
                                    }
                                    Text { text: "% wide"; vertical-alignment: center; color: #333333; }
                                    Button { text: "✕"; enabled: rings-enabled && !busy; clicked => { remove-ring(idx); shape-changed(); } }
                                }
                            }
                            HorizontalBox {
                                alignment: center;
                                Button { text: "+ Add ring"; enabled: rings-enabled && !busy; clicked => { add-ring(); shape-changed(); } }
                            }
                            // Surface texture — one toggle for the fine ribs
                            // (depth + spacing).
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                CheckBox {
                                    checked <=> texture-enabled;
                                    enabled: !busy;
                                    toggled => { shape-changed(); }
                                }
                                Text { text: "Surface texture depth"; vertical-alignment: center; color: #333333; }
                                StepBox {
                                    minimum: 0;
                                    maximum: 50;
                                    value: ridge-texture-depth-tenths-mm;
                                    enabled: texture-enabled && !busy;
                                    edited(v) => { ridge-texture-depth-tenths-mm = v; shape-changed(); }
                                }
                                Text { text: "×0.1 mm"; vertical-alignment: center; color: #333333; }
                            }
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                Text { text: "Surface texture spacing"; vertical-alignment: center; color: #333333; }
                                StepBox {
                                    minimum: 10;
                                    maximum: 300;
                                    value: ridge-texture-spacing-tenths-mm;
                                    enabled: texture-enabled && !busy;
                                    edited(v) => { ridge-texture-spacing-tenths-mm = v; shape-changed(); }
                                }
                                Text { text: "×0.1 mm"; vertical-alignment: center; color: #333333; }
                            }
                            // Side pinch — one-sided flattening.
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                CheckBox {
                                    checked <=> side-pinch-enabled;
                                    enabled: !busy;
                                    toggled => { shape-changed(); }
                                }
                                Text { text: "Side pinch depth"; vertical-alignment: center; color: #333333; }
                                StepBox {
                                    minimum: 0;
                                    maximum: 50;
                                    value: ridge-side-pinch-tenths-mm;
                                    enabled: side-pinch-enabled && !busy;
                                    edited(v) => { ridge-side-pinch-tenths-mm = v; shape-changed(); }
                                }
                                Text { text: "×0.1 mm"; vertical-alignment: center; color: #333333; }
                            }
                            // Tip relief — outward pocket near the deep end.
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                CheckBox {
                                    checked <=> tip-relief-enabled;
                                    enabled: !busy;
                                    toggled => { shape-changed(); }
                                }
                                Text { text: "Tip relief depth"; vertical-alignment: center; color: #333333; }
                                StepBox {
                                    minimum: 0;
                                    maximum: 50;
                                    value: ridge-tip-relief-tenths-mm;
                                    enabled: tip-relief-enabled && !busy;
                                    edited(v) => { ridge-tip-relief-tenths-mm = v; shape-changed(); }
                                }
                                Text { text: "×0.1 mm"; vertical-alignment: center; color: #333333; }
                            }
                            // Feature orientation — the angle for the one-sided
                            // features (side pinch / texture). Off → 0°.
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                CheckBox {
                                    checked <=> orientation-enabled;
                                    enabled: !busy;
                                    toggled => { shape-changed(); }
                                }
                                Text { text: "Feature orientation"; vertical-alignment: center; color: #333333; }
                                StepBox {
                                    minimum: 0;
                                    maximum: 360;
                                    value: ridge-orientation-deg;
                                    enabled: orientation-enabled && !busy;
                                    edited(v) => { ridge-orientation-deg = v; shape-changed(); }
                                }
                                Text { text: "°"; vertical-alignment: center; color: #333333; }
                            }
                        }
                    }
                    HorizontalBox {
                        alignment: center;
                        Button {
                            text: "Continue";
                            primary: true;
                            enabled: !busy;
                            clicked => { commit-plug(cavity-inset-mm); }
                        }
                    }
                }

                // Step 5 — make the printable mold pieces (runs the cast).
                if viewed-number == 5: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    Text {
                        text: "CortenForge builds the printable mold from your cleaned scan and silicone design. This runs the full cast — print quality takes around fifteen minutes (the faster preview is a few), and the window stays responsive while it works.";
                        horizontal-alignment: center;
                        font-size: 16px;
                        color: #444444;
                        wrap: word-wrap;
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "Quality"; vertical-alignment: center; color: #333333; }
                        quality-combo := ComboBox {
                            // 0.5 mm is the print-quality default (the physical
                            // fit-test print was 0.5 mm); 1.5 mm is a faster preview.
                            model: ["Fine — 0.5 mm (print quality)", "Fast — 1.5 mm (preview)"];
                            current-index: 0;
                            enabled: !busy;
                        }
                        Button {
                            text: busy ? "Making molds…" : "Make molds";
                            primary: true;
                            enabled: !busy;
                            clicked => { make-molds(quality-combo.current-index); }
                        }
                    }

                    // Choose which parts to generate. Everything is checked by
                    // default (a full cast); uncheck to regenerate just the
                    // piece(s) you need (e.g. one plug) and skip the rest.
                    Rectangle {
                        background: #eef1f4;
                        border-radius: 10px;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;
                            HorizontalBox {
                                alignment: center;
                                spacing: 8px;
                                Text {
                                    text: "Parts to generate";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: #333333;
                                    vertical-alignment: center;
                                }
                                Button { text: "All"; enabled: !busy; clicked => { select-all-parts(); } }
                                Button { text: "None"; enabled: !busy; clicked => { select-no-parts(); } }
                            }
                            for part[idx] in parts: HorizontalBox {
                                alignment: start;
                                spacing: 6px;
                                // Empty-text CheckBox + an explicitly-coloured
                                // Text: the widget's built-in label uses the
                                // theme foreground (white on a dark-mode OS),
                                // invisible on the light panel — every other
                                // label in this app sets #333333 for the same
                                // reason.
                                CheckBox {
                                    checked: part.checked;
                                    enabled: !busy;
                                    toggled => { set-part-checked(idx, self.checked); }
                                }
                                Text {
                                    text: part.label;
                                    color: #333333;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    if molds-summary != "": Rectangle {
                        background: #eef3ee;
                        border-radius: 10px;
                        VerticalBox {
                            padding: 14px;
                            Text {
                                text: molds-summary;
                                font-size: 16px;
                                color: #2e4d2e;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
                // Step 6 — save the printable files + hand off to the slicer.
                if viewed-number == 6: VerticalLayout {
                    spacing: 14px;
                    vertical-stretch: 1;
                    Text {
                        text: "Your mold pieces are ready to print. Save them to a folder, then open that folder in your slicer (like OrcaSlicer) and print each piece. The printed molds are what you'll pour silicone into.";
                        horizontal-alignment: center;
                        font-size: 16px;
                        color: #444444;
                        wrap: word-wrap;
                    }
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;
                        Button {
                            text: busy ? "Saving…" : (has-print-export ? "Save again…" : "Save files for printing…");
                            primary: true;
                            enabled: !busy;
                            clicked => { export-print(); }
                        }
                        if has-print-export: Button {
                            text: "Open folder";
                            enabled: !busy;
                            clicked => { open-export-folder(); }
                        }
                    }
                    if print-summary != "": Rectangle {
                        background: #eef3ee;
                        border-radius: 10px;
                        VerticalBox {
                            padding: 14px;
                            Text {
                                text: print-summary;
                                font-size: 16px;
                                color: #2e4d2e;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
                // Step 7 — the guided pour assistant (plan + pot-life timer).
                if viewed-number == 7: VerticalLayout {
                    spacing: 12px;
                    vertical-stretch: 1;
                    // Full plan, for reference (innermost layer first).
                    Rectangle {
                        background: #f3f4f6;
                        border-radius: 10px;
                        VerticalBox {
                            padding: 12px;
                            Text {
                                text: pour-plan-text;
                                font-size: 14px;
                                color: #333333;
                                wrap: word-wrap;
                            }
                        }
                    }
                    // Active layer + timer (hidden once every layer is poured).
                    if !pour-complete: VerticalLayout {
                        spacing: 10px;
                        Text {
                            text: pour-active-text;
                            font-size: 16px;
                            color: #1565c0;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                        if pour-timer-running: Text {
                            text: pour-timer-text;
                            font-size: 22px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            color: pour-timer-urgency == 2
                                ? #c62828
                                : (pour-timer-urgency == 1 ? #e65100 : #2e7d32);
                        }
                        HorizontalBox {
                            alignment: center;
                            spacing: 8px;
                            Button {
                                // Always enabled: re-clicking restarts the clock
                                // (e.g. after the pot life expired and you remixed).
                                text: pour-timer-running ? "Restart timer" : "Start pour timer";
                                clicked => { start-pour-timer(); }
                            }
                            Button {
                                text: "Mark this layer poured →";
                                primary: true;
                                clicked => { mark-poured(); }
                            }
                        }
                    }
                    if pour-complete: Rectangle {
                        background: #eef3ee;
                        border-radius: 10px;
                        VerticalBox {
                            padding: 16px;
                            Text {
                                text: "🎉 All layers poured — your device is complete! Let each layer cure fully before unmolding.";
                                font-size: 18px;
                                color: #2e4d2e;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
            }
            }
        }

        // ── footer ──────────────────────────────────────────────
        HorizontalBox {
            spacing: 12px;
            Button {
                text: "← Back";
                // Hold navigation while a background run (simplify / mold-gen)
                // is in flight, so it can't be interrupted mid-flight.
                enabled: can-back && !busy;
                clicked => { back(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Help";
                enabled: !busy;
                clicked => { help(); }
            }
            Button {
                text: "Next →";
                enabled: can-next && !busy;
                primary: true;
                clicked => { next(); }
            }
        }

        // Cendrillon's UI is built with Slint (used under its royalty-free
        // desktop license) — credit where it's due.
        Text {
            text: "UI built with Slint";
            font-size: 12px;
            color: #8a909a;
            horizontal-alignment: right;
        }
    }

    // Liability/age gate — last child so it paints on top of the wizard, sized
    // to fill the window. Shown until the user accepts (in-memory, every launch).
    if !root.waiver-accepted: WaiverPage {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        accept => { root.accept-waiver(); }
        quit => { root.quit-app(); }
    }
}
