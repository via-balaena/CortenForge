<mujoco model="double_pendulum">
  <!-- Canonical conformance model (b): double pendulum.
       nv=2, nq=2. Two hinge joints in chain under gravity.

       Pipeline stages exercised:
       - FK: chain propagation through two joints
       - CRBA: 2×2 mass matrix with off-diagonal coupling terms
       - RNE: Coriolis terms (qfrc_bias) — gravity produces non-zero
         torques on both joints at qpos0 due to offset masses
       - Passive: spring on joint1 (springref=0.2) for non-zero passive
         force at qpos0
       - Integration: demonstrates chaotic divergence over many steps

       qpos0 design: both links horizontal with offset mass centers,
       gravity torques are non-zero. Spring on joint1 with springref≠0.
  -->
  <option gravity="0 0 -9.81" timestep="0.002"/>
  <worldbody>
    <body name="upper" pos="0 0 1.5">
      <joint name="joint1" type="hinge" axis="0 1 0"
             stiffness="5" damping="0.3" springref="0.2"/>
      <geom name="upper_geom" type="capsule" fromto="0 0 0 0.3 0 0"
            size="0.02" mass="1.0"/>

      <body name="lower" pos="0.3 0 0">
        <joint name="joint2" type="hinge" axis="0 1 0"
               damping="0.2"/>
        <geom name="lower_geom" type="capsule" fromto="0 0 0 0.25 0 0"
              size="0.015" mass="0.5"/>
      </body>
    </body>
  </worldbody>
</mujoco>
